rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function chatDoc(chatId) {
      return firestore.get(/databases/(default)/documents/chats/$(chatId));
    }

    function isChatMember(chatId) {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/chats/$(chatId))
        && request.auth.uid in chatDoc(chatId).data.memberIds;
    }

    match /chats/{chatId}/attachments/{attachmentId}/{fileName} {
      allow read: if isChatMember(chatId);
      allow write: if isChatMember(chatId)
        && request.resource.size < 25 * 1024 * 1024
        && request.resource.contentType.matches("image/.*|video/.*");
    }
  }
}
