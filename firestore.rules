rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isChatMember(chatId) {
      return signedIn()
        && exists(/databases/$(database)/documents/chats/$(chatId))
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.memberIds;
    }

    function chatMissingOrMember(chatId) {
      return signedIn()
        && (
          !exists(/databases/$(database)/documents/chats/$(chatId))
          || request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.memberIds
        );
    }

    function validChatCreate() {
      return signedIn()
        && request.resource.data.type == "direct"
        && request.resource.data.memberIds is list
        && request.resource.data.memberIds.size() == 2
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.createdBy == request.auth.uid;
    }

    function sameMembers() {
      return request.resource.data.memberIds == resource.data.memberIds;
    }

    function validMessageBase() {
      return signedIn()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 2000
        && request.resource.data.attachmentIds is list
        && request.resource.data.deletedForEveryone == false;
    }

    function validTextMessage() {
      return validMessageBase()
        && request.resource.data.type == "text"
        && request.resource.data.text.size() > 0
        && request.resource.data.attachmentIds.size() == 0
        && !request.resource.data.keys().hasAny(["attachments"]);
    }

    function validMediaMessage(chatId) {
      return validMessageBase()
        && request.resource.data.type == "media"
        && request.resource.data.attachmentIds.size() == 1
        && request.resource.data.attachments is list
        && request.resource.data.attachments.size() == 1
        && request.resource.data.attachments[0].id == request.resource.data.attachmentIds[0]
        && request.resource.data.attachments[0].type in ["image", "video"]
        && request.resource.data.attachments[0].downloadURL is string
        && request.resource.data.attachments[0].storagePath is string
        && existsAfter(/databases/$(database)/documents/chats/$(chatId)/attachments/$(request.resource.data.attachmentIds[0]));
    }

    function validAttachmentCreate() {
      return signedIn()
        && request.resource.data.keys().hasOnly([
          "contentType",
          "createdAt",
          "downloadURL",
          "durationMillis",
          "height",
          "id",
          "messageId",
          "sizeBytes",
          "storagePath",
          "type",
          "uploadedBy",
          "width"
        ])
        && request.resource.data.type in ["image", "video"]
        && request.resource.data.contentType is string
        && request.resource.data.downloadURL is string
        && request.resource.data.storagePath is string
        && request.resource.data.uploadedBy == request.auth.uid;
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow create: if isSelf(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email is string;
      allow update: if isSelf(uid)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email;
      allow delete: if false;
    }

    match /chats/{chatId} {
      allow get: if chatMissingOrMember(chatId);
      allow list: if signedIn() && request.auth.uid in resource.data.memberIds;
      allow create: if validChatCreate();
      allow update: if signedIn()
        && request.auth.uid in resource.data.memberIds
        && sameMembers();
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isChatMember(chatId);
        allow create: if isChatMember(chatId)
          && (validTextMessage() || validMediaMessage(chatId));
        allow update, delete: if false;
      }

      match /attachments/{attachmentId} {
        allow read: if isChatMember(chatId);
        allow create: if isChatMember(chatId) && validAttachmentCreate();
        allow update, delete: if false;
      }
    }
  }
}
